{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "xyzizz-orb-drift",
  "main": "src/index.js",
  "compatibility_date": "2026-03-05",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "xyzizz.xyz",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "single-page-application"
  }
}
